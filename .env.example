# ==================== GitHub配置 ====================
# 获取GitHub Token: https://github.com/settings/tokens
# 权限: repo (full control of private repositories)
GITHUB_TOKEN=your_github_token_here

# ==================== Reddit配置 ====================
# 1. 访问: https://www.reddit.com/prefs/apps
# 2. 点击 "create app" 或 "create another app"
# 3. 填写信息:
#    - name: Skill Discovery
#    - app type: script
#    - description: Auto-posting tool for Skill Discovery project
#    - about url: https://github.com/ei060/skill-discovery
#    - redirect uri: http://localhost:8080
# 4. 保存后获取 client_id 和 client_secret

REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password

# ==================== Twitter配置（可选）====================
# 获取Twitter API: https://developer.twitter.com/
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_SECRET=your_twitter_access_secret

# ==================== 其他配置 ====================
# GitHub仓库（默认: ei060/skill-discovery）
GITHUB_REPO=ei060/skill-discovery

# Release版本标签
RELEASE_TAG=v1.0.0
